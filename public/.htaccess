<IfModule mod_rewrite.c>
    RewriteEngine On
    RewriteBase /

    # 1. Archivos y directorios reales — no tocar
    RewriteCond %{REQUEST_FILENAME} -f [OR]
    RewriteCond %{REQUEST_FILENAME} -d
    RewriteRule ^ - [L]

    # 2. www → non-www (HTTP y HTTPS)
    RewriteCond %{HTTP_HOST} ^www\.(.+)$ [NC]
    RewriteRule ^ https://%1%{REQUEST_URI} [R=308,L]

    # 3. Eliminar barra final (excepto raíz)
    RewriteCond %{REQUEST_URI} ^/(.+)/$
    RewriteRule ^(.+)/$ /$1 [R=308,L]

    # 4. Control panel shortcut
    RewriteRule ^control/?$ /control/reserves-pendents [R=301,L]

    # 5. Front controller
    RewriteRule ^ index.php [L]
</IfModule>

<IfModule mod_headers.c>
    Header set Access-Control-Allow-Origin "*"
    Header set Access-Control-Allow-Methods "GET, POST, PUT, DELETE, OPTIONS"
    Header set Access-Control-Allow-Headers "Content-Type"
</IfModule>

<FilesMatch "\.svg$">
    Header set Content-Type "image/svg+xml"
</FilesMatch>
