{
    "plugins": [
        "@prettier/plugin-php"
    ],
    "phpVersion": "8.5",
    "tabWidth": 4,
    "semi": true,
    "singleQuote": true,
    "printWidth": 80,
    "useTabs": false,
    "trailingComma": "es5",
    "bracketSpacing": true,
    "jsxBracketSameLine": true,
    "proseWrap": "never",
    "bracketSameLine": true
}
