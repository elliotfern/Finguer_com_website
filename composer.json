{
  "name": "elliot/02_finguer_com",
  "description": "Finguer.com website - backend (PHP) and frontend (TypeScript).",
  "type": "project",
  "license": "MIT",
  "autoload": {
    "psr-4": {
      "App\\": "src/backend/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "App\\Tests\\": "src/backend/Tests/"
    }
